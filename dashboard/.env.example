# SkySense Dashboard - Environment Variables
# Copy this file to .env.local and fill in your values

# Dashboard API base URL (used by ESP firmware to push sensor data)
# In production, replace with your actual deployment URL
NEXT_PUBLIC_API_URL=http://localhost:3000

# WebSocket URL for real-time updates (optional)
# NEXT_PUBLIC_WS_URL=wss://skysense.yansha.dev/ws/api
